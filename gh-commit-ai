            "https://api.anthropic.com/v1/messages" \
            "$json_payload" \
            "$temp_response" \
            "$temp_error" \
            "Anthropic" \
            -H "Content-Type: application/json" \
            -H "x-api-key: $ANTHROPIC_API_KEY" \
